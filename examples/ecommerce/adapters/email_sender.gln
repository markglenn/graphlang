adapter email_sender
  description "Send transactional emails via SMTP"
  type smtp
  config
    host env(SMTP_HOST)
    port env(SMTP_PORT)
    user env(SMTP_USER)
    password env(SMTP_PASSWORD)
  end

  action send
    input to : string @format(email)
    input subject : string
    input template : string
    input data : json @justification("Email template data varies per template")
    output message_id : string
    output status : enum(sent, queued, failed)
  end
end
